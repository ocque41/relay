# =============================================================================
# Relay — environment variables
# =============================================================================
# Copy to `.env` and fill in. On Vercel, use `vercel env pull .env --yes`
# after setting these via `vercel env add <NAME> production`.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon Postgres — set up via the Vercel Marketplace integration)
# -----------------------------------------------------------------------------
DATABASE_URL=
# auto | neon-http | postgres. Leave blank for auto: localhost uses postgres,
# hosted URLs use Neon HTTP.
DATABASE_DRIVER=

# -----------------------------------------------------------------------------
# Core crypto
# -----------------------------------------------------------------------------
# 32-byte base64 — AES-256-GCM key for every encrypted column.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# 32+ chars — HS256 session JWT signing key.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Shared secret for the inbound email webhook. Relay expects SendGrid Inbound
# Parse to POST to `/v1/webhooks/email?secret=$EMAIL_SENDGRID_SECRET`; any value
# that mismatches returns 401. See docs/inbound-email-setup.md.
# Generate:  openssl rand -hex 32
EMAIL_SENDGRID_SECRET=

# PKCS#8 RSA private key (base64-encoded PEM) used to sign attestation JWTs
# for the drop-in integrator flow (`POST /v1/integrator/auth/attest`). The
# public half is published at `/.well-known/jwks.json` so any integrator can
# verify.
# Generate:
#   openssl genpkey -algorithm RSA -pkcs8 -out relay-jwt.pem -pkeyopt rsa_keygen_bits:2048
#   base64 -i relay-jwt.pem | tr -d '\n'
RELAY_JWT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Inbound email
# -----------------------------------------------------------------------------
# Catch-all domain. Every user gets `<alias>@<CATCHALL_DOMAIN>` and every
# provider signup gets `signup-<id>@<CATCHALL_DOMAIN>`. Needs MX records.
CATCHALL_DOMAIN=inbox.cumulush.com

# Public base URL the app reports to itself for building email links,
# OTP confirmation URLs, CLI-login redirects, etc.
APP_BASE_URL=https://relay.cumulush.com

# -----------------------------------------------------------------------------
# Outbound email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# From-address for all transactional mail. Must be on a Resend-verified domain.
RELAY_FROM_ADDRESS=noreply@cumulush.com

# -----------------------------------------------------------------------------
# Passkeys (WebAuthn)
# -----------------------------------------------------------------------------
# Hostname only — no scheme/port.
WEBAUTHN_RP_ID=relay.cumulush.com
WEBAUTHN_RP_NAME=Relay
# Comma-separated to support multiple origins (e.g. during a domain cutover).
WEBAUTHN_ORIGIN=https://relay.cumulush.com

# -----------------------------------------------------------------------------
# Built-in providers (optional — only needed if you use them)
# -----------------------------------------------------------------------------
NEON_API_KEY=
VERCEL_API_TOKEN=

# -----------------------------------------------------------------------------
# Stripe (billing — Phase 4)
# -----------------------------------------------------------------------------
# Use a Stripe test key in preview/staging and a live key in production.
STRIPE_SECRET_KEY=
# whsec_… — shared secret for POST /v1/webhooks/stripe (Stripe Dashboard →
# Developers → Webhooks; or `stripe listen --print-secret` during local dev).
STRIPE_WEBHOOK_SECRET=
# price_… ids for each subscription plan (created in the Stripe Dashboard).
STRIPE_PRICE_FOUNDERS=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=

# -----------------------------------------------------------------------------
# Billing enforcement (integrator-only revenue model)
# -----------------------------------------------------------------------------
# off | warn | enforce. Controls the integrator-subscription + signup-quota
# gates in src/server/routes/signups.ts, actions.ts, etc. Start in `off` for
# local dev; flip to `warn` in preview and `enforce` in prod (Phase 9).
BILLING_ENFORCEMENT=off

# on | off. Repeat-user fairness debounce for key-lifecycle actions
# (mint / reveal / rotate / revoke). When `on`, the first such action of
# the UTC day on a (user, tenant, provider) triple bills one integrator
# action; subsequent same-day, same-triple actions are free against the
# integrator quota. Signups and deletes are never debounced. Per-user
# abuse caps still apply on top.
BILLING_FAIRNESS=on

# -----------------------------------------------------------------------------
# Stripe plan price IDs — set per-env via `vercel env add`. Each plan maps to
# a recurring monthly price on the Stripe account behind STRIPE_SECRET_KEY.
# STRIPE_PRICE_FOUNDERS stays blank (Founders is a server-side trial, never
# a Stripe subscription).
# -----------------------------------------------------------------------------
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# -----------------------------------------------------------------------------
# Stripe yearly plan price IDs — yearly variants ship at a 17% discount on
# the annualised monthly price (≈ "2 months free"). Founders is a free trial
# and stays monthly-only. Provision via:
#   STRIPE_SECRET_KEY=… npx tsx scripts/stripe-provision-prices.ts
# -----------------------------------------------------------------------------
STRIPE_PRICE_BUILDER_YEARLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_SCALE_YEARLY=

# -----------------------------------------------------------------------------
# Stripe credit-pack price IDs — one-shot purchases (mode=payment) that add
# extra actions to a tenant's current period. Per-plan SKU at 20% below the
# plan's overage rate:
#   Builder: 500 actions / $20    Starter: 5,000 / $80
#   Growth:  25,000 / $400        Scale:   100,000 / $800
# Provision via the same scripts/stripe-provision-prices.ts script.
# -----------------------------------------------------------------------------
STRIPE_PRICE_CREDITS_BUILDER=
STRIPE_PRICE_CREDITS_STARTER=
STRIPE_PRICE_CREDITS_GROWTH=
STRIPE_PRICE_CREDITS_SCALE=

# -----------------------------------------------------------------------------
# Abuse prevention (Phase 4)
# -----------------------------------------------------------------------------
# off | warn | enforce. Controls the per-user monthly signup cap in
# src/server/abuse/signup-limit.ts. Start in `warn` (log breaches, don't 429)
# for the first two weeks after launch; flip to `enforce` once the observed
# p95 is well below the cap.
ABUSE_ENFORCEMENT=warn
# Hard per-user signup cap per calendar month. Default 50. Individual users
# can have a higher ceiling via users.signup_limit_override set by the admin
# raise-limit route.
USER_SIGNUP_MONTHLY_LIMIT=50

# -----------------------------------------------------------------------------
# Cron (optional)
# -----------------------------------------------------------------------------
# If set, `/v1/cron/gc` requires `Authorization: Bearer $CRON_SECRET`.
# Leave blank to allow unauthenticated calls (fine — the endpoint only deletes
# already-expired rows and returns counts).
CRON_SECRET=

# -----------------------------------------------------------------------------
# Observability (Phase 0)
# -----------------------------------------------------------------------------
# Sentry DSN. Leave blank in local dev — the SDK no-ops without a DSN.
SENTRY_DSN=
# Trace sampling rate for Sentry performance data (0.0–1.0). Defaults to 0.1.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Pino log level: fatal | error | warn | info | debug | trace. Defaults to
# debug in non-production, info in production.
LOG_LEVEL=info
